{
  "name": "zudo-codemirror-wisdom",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:cm6": "bash scripts/build-cm6-bundle.sh",
    "dev": "run-p dev:zfb dev:history",
    "dev:zfb": "zfb dev",
    "dev:zfb:network": "zfb dev --host 0.0.0.0",
    "dev:network": "run-p dev:zfb:network dev:history",
    "dev:history": "doc-history-server --port 4322 --content-dir src/content/docs --locale ja:src/content/docs-ja",
    "build": "pnpm build:cm6 && zfb build",
    "preview": "zfb preview",
    "check": "zfb check",
    "check:html": "html-validate \"dist/**/*.html\"",
    "check:pin-parity": "node scripts/check-pin-parity.mjs",
    "check:wrangler-pin": "node scripts/check-wrangler-pin.mjs",
    "check:links": "node scripts/check-links.js --strict-broken --allowlist=.check-links-allowlist",
    "check:template-drift": "bash scripts/check-template-drift.sh",
    "format:md": "pnpm dlx @takazudo/mdx-formatter --write \"src/content/**/*.{md,mdx}\"",
    "format:md:check": "pnpm dlx @takazudo/mdx-formatter --check \"src/content/**/*.{md,mdx}\"",
    "b4push": "bash scripts/run-b4push.sh",
    "setup:doc-skill": "SKILL_NAME=codemirror-wisdom bash scripts/setup-doc-skill.sh",
    "setup:doc-skill-silent": "SKILL_NAME=codemirror-wisdom bash scripts/setup-doc-skill.sh --silent",
    "setup:doc-skill:claude": "SKILL_NAME=codemirror-wisdom bash scripts/setup-doc-skill.sh --target claude",
    "setup:doc-skill:codex": "SKILL_NAME=codemirror-wisdom bash scripts/setup-doc-skill.sh --target codex",
    "setup:doc-skill:both": "SKILL_NAME=codemirror-wisdom bash scripts/setup-doc-skill.sh --target both"
  },
  "dependencies": {
    "@takazudo/zfb": "0.1.0-next.89",
    "@takazudo/zfb-runtime": "0.1.0-next.89",
    "@takazudo/zfb-adapter-cloudflare": "0.1.0-next.89",
    "@takazudo/zfb-md-wasm": "0.1.0-next.89",
    "@takazudo/zudo-doc": "^4.2.1",
    "@takazudo/zudo-doc-history-server": "^4.2.1",
    "@takazudo/zdtp": "0.4.9",
    "zod": "^4.3.6",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.6",
    "shiki": "^4.0.2",
    "@shikijs/transformers": "^4.0.0",
    "gray-matter": "^4.0.0",
    "mermaid": "^11.12.3",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "katex": "^0.16.38",
    "minisearch": "^7.2.0",
    "diff": "^8.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "create-zudo-doc": "^4.2.1",
    "html-validate": "^10.0.0",
    "pagefind": "^1.4.0",
    "npm-run-all2": "^7.0.2",
    "tsx": "^4.21.0",
    "wrangler": "4.85.0",
    "esbuild": "^0.28.0",
    "codemirror": "^6.0.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.39.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/language": "^6.12.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/lang-javascript": "^6.2.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@lezer/highlight": "^1.2.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/diff": "^8.0.0"
  }
}
